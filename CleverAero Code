#include <Arduino.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <WiFiS3.h>
#include <BlynkSimpleWifi.h>

// ================= LCD =================
LiquidCrystal_I2C lcd(0x27, 16, 2);

// ================= RELAY =================
#define RELAY_PIN 7

// ================= BLYNK PINS =================
#define PIN_PM25          V0
#define PIN_FANSTATUS     V1
#define PIN_FANCONTROL    V2
#define PIN_MODEAUTO      V3
#define PIN_AQI           V4
#define PIN_PM25_CHART    V5
#define PIN_PM25_HISTORY  V6
#define PIN_CUSTOM_MIN    V7
#define PIN_ALERT_LIMIT   V8
#define PIN_FILTERED_PM   V9
#define PIN_RESET_FILTER V10

// ================= PMS =================
uint8_t buffer[32];

// ================= Change Filter =================
unsigned long fanOnStart = 0;
unsigned long totalFanOnTime = 0;  // ms
bool filterAlertSent = false;

// กำหนดอายุไส้กรอง (ตัวอย่าง 100 ชั่วโมง)
const unsigned long FILTER_LIFE_MS = 100UL * 60UL * 60UL * 1000UL;

// ================= MOVING AVERAGE =================
#define N_AVG 5
int pmBuf[N_AVG];
int pmIdx = 0;
bool pmBufInit = false;

// ================= SYSTEM =================
const int PM_ON  = 20;
const int PM_OFF = 18;

int fanState = 0;
bool autoMode = true;

int pm25Value = 0;
int customMinPM = 0;

int alertPM = 20;
bool alertSent = false;

// ================= HISTORY =================
int pmHistoryValue = 0;
unsigned long lastHistoryMs = 0;
const unsigned long HISTORY_INTERVAL = 60000UL;

// ================= FUNCTIONS =================
int addAndGetAvg(int v) {
  pmBuf[pmIdx] = v;
  pmIdx = (pmIdx + 1) % N_AVG;

  static int filled = 0;
  if (!pmBufInit) {
    filled++;
    if (filled >= N_AVG) pmBufInit = true;
  }

  long sum = 0;
  int count = pmBufInit ? N_AVG : pmIdx;
  for (int i = 0; i < count; i++) sum += pmBuf[i];
  return count ? sum / count : v;
}

int pm25_to_aqi(int pm) {
  struct BP { int pml, pmh, aqil, aqih; };
  BP t[] = {
    {0,12,0,50},{12,35,51,100},{35,55,101,150},
    {55,150,151,200},{150,250,201,300},
    {250,350,301,400},{350,500,401,500}
  };
  for (int i = 0; i < 7; i++)
    if (pm >= t[i].pml && pm <= t[i].pmh)
      return (t[i].aqih - t[i].aqil) * (pm - t[i].pml) /
             (t[i].pmh - t[i].pml) + t[i].aqil;
  return 500;
}

bool readPMS(int &pm25) {
  if (Serial1.available() < 32) return false;
  if (Serial1.peek() != 0x42) { Serial1.read(); return false; }
  Serial1.readBytes(buffer, 32);
  if (buffer[0] != 0x42 || buffer[1] != 0x4D) return false;
  pm25 = (buffer[12] << 8) | buffer[13];
  return true;
}

// ================= BLYNK =================
BLYNK_WRITE(PIN_MODEAUTO) {
  autoMode = param.asInt() == 0;
}

BLYNK_WRITE(PIN_FANCONTROL) {
  if (!autoMode && customMinPM == 0) {
    fanState = param.asInt();
  }
}

BLYNK_WRITE(PIN_CUSTOM_MIN) {
  customMinPM = param.asInt();
}

BLYNK_WRITE(PIN_ALERT_LIMIT) {
  alertPM = param.asInt();
  alertSent = false;
}

BLYNK_WRITE(PIN_RESET_FILTER) {
  totalFanOnTime = 0;
  filterAlertSent = false;
  fanOnStart = 0;
  Serial.println("Filter timer reset");
}

// ================= SETUP =================
void setup() {
  Serial.begin(115200);
  Wire.begin();

  lcd.init();
  lcd.backlight();

  // ===== SCREEN =====
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Smart Aero");
  lcd.setCursor(0, 1);
  lcd.print("PM2.5 Monitor");
  delay(2000);

  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Initializing...");
  delay(1000);

  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Connecting WiFi");
  lcd.setCursor(0, 1);
  lcd.print("Please wait...");
  // ========================

  Serial1.begin(9600);

  pinMode(RELAY_PIN, OUTPUT);
  digitalWrite(RELAY_PIN, LOW);

  Blynk.begin(BLYNK_AUTH_TOKEN, "TP-Link_685E", "79320887");

  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("System Ready");
  delay(1000);
  lcd.clear();

  lastHistoryMs = millis();
}

// ================= LOOP =================
void loop() {
  Blynk.run();

  int pm_raw;
  if (readPMS(pm_raw)) {
    pm25Value = pm_raw;
    int pm_avg = addAndGetAvg(pm_raw);

    // ---------- ALERT ----------
    if (pm_avg > alertPM && !alertSent) {
      Blynk.logEvent("pm_alert", "PM2.5 = " + String(pm_avg));
      alertSent = true;
    }
    if (pm_avg <= alertPM) alertSent = false;

    // ---------- FAN LOGIC ----------
    if (autoMode) {
      if (pm_avg > PM_ON) fanState = 1;
      else if (pm_avg < PM_OFF) fanState = 0;
    } else {
      if (customMinPM > 0) {
        fanState = (pm_avg > customMinPM);
      }
      // customMinPM == 0 → ใช้ปุ่ม V2
    }

    digitalWrite(RELAY_PIN, fanState ? HIGH : LOW);
    Blynk.virtualWrite(PIN_FANSTATUS, fanState);

    int aqi = pm25_to_aqi(pm_avg);
    Blynk.virtualWrite(PIN_PM25, pm_avg);
    Blynk.virtualWrite(PIN_AQI, aqi);
    Blynk.virtualWrite(PIN_PM25_CHART, pm_avg);

    lcd.clear();
    lcd.setCursor(0,0);
    lcd.print("PM2.5:");
    lcd.print(pm_avg);
    lcd.setCursor(0,1);
    lcd.print("Fan:");
    lcd.print(fanState ? "ON " : "OFF");
    lcd.print(" AQI:");
    lcd.print(aqi);
  }

  // ===== นับเวลาการใช้งานพัดลม =====
  if (fanState == 1) {
   if (fanOnStart == 0) {
    fanOnStart = millis();
  }
} else {
  if (fanOnStart > 0) {
    totalFanOnTime += millis() - fanOnStart;
    fanOnStart = 0;
  }
}

// ===== แจ้งเตือนเปลี่ยนไส้กรอง =====
 if (totalFanOnTime >= FILTER_LIFE_MS && !filterAlertSent) {
  Blynk.logEvent("filter_change", "ถึงเวลาเปลี่ยนไส้กรองอากาศ");
  Serial.println("🔧 FILTER CHANGE ALERT");
  filterAlertSent = true;
}

  // ---------- HISTORY ----------
  if (millis() - lastHistoryMs >= HISTORY_INTERVAL) {
    int filtered = pmHistoryValue - pm25Value;
    if (filtered < 0) filtered = 0;
    Blynk.virtualWrite(PIN_FILTERED_PM, filtered);
    pmHistoryValue = pm25Value;
    lastHistoryMs = millis();
  }
}
